  { q:'Failure rate: 5 failures observed in 10,000 operating hours. Calculate failure rate λ.', diff:'easy',
    choices:['0.0005/hr','0.005/hr','0.05/hr','0.5/hr'], correct:0,
    solution:'λ = number of failures / total operating hours\n= 5/10000 = 0.0005 failures/hour\n\n✓ Answer: λ = 0.0005/hr' },
];

// Generate MTBF variations
[500,1000,1500,2000,3000,5000,8000,10000].forEach(mtbf => {
  [100,200,500,1000].forEach(t => {
    if(t<mtbf) {
      const r = Math.exp(-t/mtbf);
      P.push({ id:mkId(), cat:'rel', diff:'medium',
        q:`MTBF=${mtbf}hr. Reliability at t=${t}hr (exponential)?`,
        choices:[r.toFixed(4),(r-0.05).toFixed(4),(r+0.03).toFixed(4),(r*0.9).toFixed(4)],
        correct:0,
        solution:`λ=1/${mtbf}=${(1/mtbf).toFixed(6)}\nR(${t})=e^(-${(1/mtbf).toFixed(6)}×${t})=e^(-${(t/mtbf).toFixed(4)})=${r.toFixed(4)}\n\n✓ Answer: ${r.toFixed(4)}`
      });
    }
  });
});

relProblems.forEach(r => P.push({...r, id:mkId(), cat:'rel'}));

// ============ MEASUREMENT (30+) ============
const measProblems = [
  { q:'Gauge R&R: Total variation TV=10, Part variation PV=9.5. Calculate measurement system variation (GRR).', diff:'hard',
    choices:['3.12','0.50','5.00','7.00'], correct:0,
    solution:'TV² = PV² + GRR²\nGRR² = TV² - PV² = 100 - 90.25 = 9.75\nGRR = √9.75 = 3.12\n\n%GRR = (GRR/TV)×100 = 31.2%\n\n✓ Answer: GRR = 3.12' },
  { q:'Accuracy: True value = 100.0, measured values: [99.8, 100.2, 99.9, 100.1, 100.0]. Calculate bias.', diff:'easy',
    choices:['0.00','0.20','-0.20','0.10'], correct:0,
    solution:'Mean measured = (99.8+100.2+99.9+100.1+100.0)/5 = 500.0/5 = 100.0\nBias = Mean measured - True value = 100.0 - 100.0 = 0.00\n\n✓ Answer: Bias = 0.00' },
  { q:'Repeatability: An operator measures the same part 6 times: [25.01, 25.03, 24.99, 25.02, 25.00, 24.98]. Calculate the repeatability (standard deviation).', diff:'medium',
    choices:['0.0187','0.0500','0.0100','0.0300'], correct:0,
    solution:'Mean = 25.005\nDeviations²: 0.000025+0.000625+0.000225+0.000225+0.000025+0.000625\nΣ=0.001750\ns = √(0.001750/5) = √0.000350 = 0.0187\n\n✓ Answer: s = 0.0187' },
  { q:'Measurement uncertainty: Type A (statistical) uncertainty u_A = 0.05, Type B (systematic) uncertainty u_B = 0.03. Combined standard uncertainty?', diff:'medium',
    choices:['0.0583','0.0800','0.0300','0.0500'], correct:0,
    solution:'u_c = √(u_A² + u_B²) = √(0.0025 + 0.0009) = √0.0034 = 0.0583\n\n✓ Answer: u_c = 0.0583' },
  { q:'Expanded uncertainty: Combined uncertainty u_c=0.05, coverage factor k=2 (95%). Calculate U.', diff:'easy',
    choices:['0.10','0.05','0.025','0.20'], correct:0,
    solution:'U = k × u_c = 2 × 0.05 = 0.10\n\nResult: measured value ± 0.10 (95% confidence)\n\n✓ Answer: U = 0.10' },
];

measProblems.forEach(m => P.push({...m, id:mkId(), cat:'meas'}));

// ============ NUMERICAL METHODS (40+) ============
const numProblems = [
  { q:'Newton-Raphson: Solve x² - 4 = 0 starting from x₀=3. Find x₁.', diff:'medium',
    choices:['2.1667','2.0000','3.0000','2.5000'], correct:0,
    solution:'f(x) = x²-4, f\'(x) = 2x\nx₁ = x₀ - f(x₀)/f\'(x₀)\n= 3 - (9-4)/(6) = 3 - 5/6 = 3 - 0.8333 = 2.1667\n\n✓ Answer: x₁ = 2.1667' },
  { q:'Trapezoidal rule: Estimate ∫₀² x² dx with n=4 subintervals.', diff:'medium',
    choices:['2.75','2.67','3.00','2.50'], correct:0,
    solution:'h = (2-0)/4 = 0.5\nx: 0, 0.5, 1.0, 1.5, 2.0\nf(x): 0, 0.25, 1.0, 2.25, 4.0\n\nI ≈ (h/2)[f(0)+2f(0.5)+2f(1)+2f(1.5)+f(2)]\n= (0.5/2)[0+0.5+2.0+4.5+4.0]\n= 0.25×11.0 = 2.75\n\nExact: 8/3 = 2.667\n\n✓ Answer: 2.75' },
  { q:'Simpson\'s 1/3 rule: Estimate ∫₀² x² dx with n=4 subintervals.', diff:'hard',
    choices:['2.6667','2.7500','3.0000','2.5000'], correct:0,
    solution:'h = 0.5\nI ≈ (h/3)[f(0)+4f(0.5)+2f(1)+4f(1.5)+f(2)]\n= (0.5/3)[0+4(0.25)+2(1)+4(2.25)+4]\n= (0.5/3)[0+1+2+9+4]\n= (0.5/3)(16) = 8/3 = 2.6667\n\n✓ Answer: 2.6667 (exact!)' },
  { q:'Linear interpolation: Given (x₁,y₁)=(2,10) and (x₂,y₂)=(5,25). Find y at x=3.', diff:'easy',
    choices:['15.0','17.5','12.5','20.0'], correct:0,
    solution:'y = y₁ + (x-x₁)(y₂-y₁)/(x₂-x₁)\n= 10 + (3-2)(25-10)/(5-2)\n= 10 + 1×15/3 = 10+5 = 15.0\n\n✓ Answer: 15.0' },
  { q:'Error propagation: z = x + y. If σ_x = 0.1, σ_y = 0.2 (independent), what is σ_z?', diff:'easy',
    choices:['0.2236','0.3000','0.1000','0.0500'], correct:0,
    solution:'For z=x+y: σ_z = √(σ_x² + σ_y²)\n= √(0.01 + 0.04) = √0.05 = 0.2236\n\n✓ Answer: σ_z = 0.2236' },
  { q:'Error propagation: z = x × y. If x=10±0.1, y=5±0.2 (independent). Find σ_z.', diff:'medium',
    choices:['2.06','0.30','1.50','0.50'], correct:0,
    solution:'For z=xy: (σ_z/z)² = (σ_x/x)² + (σ_y/y)²\n(σ_z/50)² = (0.1/10)² + (0.2/5)² = 0.0001 + 0.0016 = 0.0017\nσ_z = 50×√0.0017 = 50×0.0412 = 2.06\n\n✓ Answer: σ_z = 2.06' },
  { q:'Bisection method: f(x) = x³-6x²+11x-6. Starting with [2.5, 4]. After 1 iteration, what is the midpoint?', diff:'easy',
    choices:['3.25','3.00','3.50','2.75'], correct:0,
    solution:'Midpoint = (2.5+4)/2 = 3.25\nf(3.25) = 34.33-63.38+35.75-6 = 0.703\nf(2.5) = 15.625-37.5+27.5-6 = -0.375\n\nSince f(2.5)<0 and f(3.25)>0, root is in [2.5, 3.25]\n\n✓ Answer: midpoint = 3.25' },
];

// Generate interpolation variations
[[1,5,3,15],[0,10,2,30],[10,50,20,80],[100,200,150,350]].forEach(([x1,x2,y1,y2]) => {
  const xq = (x1+x2)/2;
  const yq = y1+(xq-x1)*(y2-y1)/(x2-x1);
  P.push({ id:mkId(), cat:'num', diff:'easy',
    q:`Interpolate: (${x1},${y1}) and (${x2},${y2}). Find y at x=${xq}.`,
    choices:[yq.toFixed(1),(yq+3).toFixed(1),(yq-2).toFixed(1),(yq*1.1).toFixed(1)],
    correct:0,
    solution:`y = ${y1} + (${xq}-${x1})(${y2}-${y1})/(${x2}-${x1})\n= ${y1} + ${xq-x1}×${y2-y1}/${x2-x1} = ${yq.toFixed(1)}\n\n✓ Answer: ${yq.toFixed(1)}`
  });
});

numProblems.forEach(n => P.push({...n, id:mkId(), cat:'num'}));

return P;
}

const ALL_PROBLEMS = generateProblems();

// ===================== STATE =====================
let currentCat = 'all';
let currentDiff = 'all';
let shownCount = 20;
let answeredData = []; // from Data SDK
let localAnswers = {}; // id -> {correct, answer}

// ===================== INIT =====================
const defaultConfig = {
  app_title: 'Engineering Data Analysis Quiz',
  subtitle_text: 'Master engineering concepts through practice',
  background_color: '#0f1729',
  surface_color: '#1e293b',
  text_color: '#94a3b8',
  primary_color: '#38bdf8',
  accent_color: '#818cf8',
  font_family: 'DM Sans',
  font_size: 16
};

function applyConfig(config) {
  const c = {...defaultConfig, ...config};
  const font = `${c.font_family}, DM Sans, sans-serif`;
  const fs = c.font_size || 16;

  document.getElementById('app').style.background = c.background_color;
  document.querySelector('header').style.background = c.background_color+'ee';
  document.querySelector('header').style.borderColor = c.surface_color;

  const title = document.getElementById('el-title');
  title.textContent = c.app_title;
  title.style.color = c.primary_color;
  title.style.fontFamily = font;
  title.style.fontSize = `${fs*1.3}px`;

  const sub = document.getElementById('el-subtitle');
  sub.textContent = c.subtitle_text;
  sub.style.color = c.text_color;
  sub.style.fontFamily = font;
  sub.style.fontSize = `${fs*0.875}px`;

  document.querySelectorAll('#stats-bar > div').forEach(d => d.style.background = c.surface_color);
  document.getElementById('stat-total').style.color = c.primary_color;
  document.getElementById('stat-correct').style.color = '#4ade80';

  document.getElementById('progress-bar').style.background = `linear-gradient(90deg,${c.primary_color},${c.accent_color})`;

  document.body.style.fontFamily = font;
  document.body.style.fontSize = `${fs}px`;
}

window.elementSdk.init({
  defaultConfig,
  onConfigChange: async (config) => applyConfig(config),
  mapToCapabilities: (config) => {
    const c = {...defaultConfig,...config};
    const mk = (key) => ({
      get:()=>c[key]||defaultConfig[key],
      set:(v)=>{c[key]=v;window.elementSdk.setConfig({[key]:v})}
    });
    return {
      recolorables: [mk('background_color'),mk('surface_color'),mk('text_color'),mk('primary_color'),mk('accent_color')],
      borderables: [],
      fontEditable: mk('font_family'),
      fontSizeable: mk('font_size')
    };
  },
  mapToEditPanelValues: (config) => {
    const c = {...defaultConfig,...config};
    return new Map([['app_title',c.app_title],['subtitle_text',c.subtitle_text]]);
  }
});

// Data SDK
const dataHandler = {
  onDataChanged(data) {
    answeredData = data;
    localAnswers = {};
    data.forEach(d => { localAnswers[d.problem_id] = { correct: d.answered_correct, answer: d.user_answer }; });
    updateStats();
    renderProblems();
  }
};

(async () => {
  const r = await window.dataSdk.init(dataHandler);
  if(!r.isOk) console.error('Data SDK init failed');
  buildCatFilters();
  renderProblems();
  applyConfig(window.elementSdk.config);
})();

// ===================== UI FUNCTIONS =====================
function buildCatFilters() {
  const el = document.getElementById('cat-filters');
  let html = `<button onclick="setCat('all')" class="cat-btn px-3 py-1.5 rounded-full text-xs font-semibold" style="background:#38bdf8;color:#0f1729;" data-cat="all">All (${ALL_PROBLEMS.length})</button>`;
  CATEGORIES.forEach(c => {
    const count = ALL_PROBLEMS.filter(p=>p.cat===c.id).length;
    html += `<button onclick="setCat('${c.id}')" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium" style="background:#1e293b;color:${c.color};" data-cat="${c.id}">${c.name} (${count})</button>`;
  });
  el.innerHTML = html;
}

function setCat(cat) {
  currentCat = cat;
  shownCount = 20;
  document.querySelectorAll('.cat-btn').forEach(b => {
    const isActive = b.dataset.cat === cat;
    b.style.background = isActive ? '#38bdf8' : '#1e293b';
    b.style.color = isActive ? '#0f1729' : (b.dataset.cat==='all'?'#94a3b8':b.style.color);
  });
  renderProblems();
}

function setDifficulty(diff) {
  currentDiff = diff;
  shownCount = 20;
  document.querySelectorAll('.diff-btn').forEach(b => {
    b.style.background = '#1e293b';
    b.style.fontWeight = '500';
  });
  renderProblems();
}

function getFiltered() {
  return ALL_PROBLEMS.filter(p => {
    if(currentCat!=='all' && p.cat!==currentCat) return false;
    if(currentDiff!=='all' && p.diff!==currentDiff) return false;
    return true;
  });
}

function updateStats() {
  const total = answeredData.length;
  const correct = answeredData.filter(d=>d.answered_correct).length;
  const pct = total>0?Math.round(correct/total*100):0;
  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-correct').textContent = correct;
  document.getElementById('stat-pct').textContent = pct+'%';
  document.getElementById('score-badge').textContent = `${correct}/${total}`;
  const progressPct = Math.min(100, (total/ALL_PROBLEMS.length)*100);
  document.getElementById('progress-bar').style.width = progressPct+'%';
}

function renderProblems() {
  const filtered = getFiltered();
  const shown = filtered.slice(0, shownCount);
  const area = document.getElementById('quiz-area');

  document.getElementById('showing-count').textContent = shown.length;
  document.getElementById('total-count').textContent = filtered.length;

  area.innerHTML = shown.map((p, idx) => {
    const answered = localAnswers[p.id];
    const catInfo = CATEGORIES.find(c=>c.id===p.cat);
    const diffColor = p.diff==='easy'?'#4ade80':p.diff==='medium'?'#fbbf24':'#f87171';

    return `<div class="rounded-xl mb-4 fade-in" style="background:#1e293b;border:1px solid #334155;" id="card-${p.id}">
      <div class="p-5">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background:${catInfo.color}22;color:${catInfo.color};">${catInfo.name}</span>
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background:${diffColor}22;color:${diffColor};">${p.diff.charAt(0).toUpperCase()+p.diff.slice(1)}</span>
          <span class="mono text-xs" style="color:#475569;">#${idx+1}</span>
        </div>
        <pre class="whitespace-pre-wrap text-sm leading-relaxed mb-4" style="color:#e2e8f0;font-family:inherit;">${p.q}</pre>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-3">
          ${p.choices.map((ch,ci) => {
            let bg='#0f1729', border='#334155', tc='#cbd5e1';
            if(answered) {
              if(ci===p.correct) { bg='#052e16'; border='#4ade80'; tc='#4ade80'; }
              else if(answered.answer===String(ci) && ci!==p.correct) { bg='#450a0a'; border='#f87171'; tc='#f87171'; }
            }
            return `<button onclick="answer('${p.id}',${ci})" class="text-left px-4 py-3 rounded-lg text-sm font-medium transition-all ${answered?'pointer-events-none':''}" style="background:${bg};border:1px solid ${border};color:${tc};">${String.fromCharCode(65+ci)}) ${ch}</button>`;
          }).join('')}
        </div>
        ${answered?`<button onclick="toggleSolution('${p.id}')" class="text-xs font-semibold px-3 py-1.5 rounded-lg" style="background:#0f1729;color:#38bdf8;border:1px solid #1e3a5f;">Show Solution</button>
        <div id="sol-${p.id}" class="solution-box mt-3">
          <pre class="whitespace-pre-wrap text-sm p-4 rounded-lg mono leading-relaxed" style="background:#0f1729;color:#94a3b8;border:1px solid #334155;">${p.solution}</pre>
        </div>`:''}
      </div>
    </div>`;
  }).join('');

  lucide.createIcons();
}

async function answer(pid, choiceIdx) {
  if(localAnswers[pid]) return;
  const prob = ALL_PROBLEMS.find(p=>p.id===pid);
  const isCorrect = choiceIdx === prob.correct;

  if(answeredData.length >= 999) {
    // show inline warning
    const card = document.getElementById('card-'+pid);
    const w = document.createElement('div');
    w.className = 'p-3 rounded-lg mt-2 text-sm';
    w.style.cssText = 'background:#451a03;color:#fbbf24;border:1px solid #92400e;';
    w.textContent = 'Storage limit reached (999). Your answer is shown but not saved.';
    card.querySelector('.p-5').appendChild(w);
    localAnswers[pid] = { correct: isCorrect, answer: String(choiceIdx) };
    renderProblems();
    return;
  }

  // Optimistic UI
  localAnswers[pid] = { correct: isCorrect, answer: String(choiceIdx) };
  renderProblems();
  updateStats();

  const result = await window.dataSdk.create({
    problem_id: pid,
    answered_correct: isCorrect,
    user_answer: String(choiceIdx),
    timestamp: new Date().toISOString()
  });

  if(!result.isOk) {
    delete localAnswers[pid];
    renderProblems();
  }
}

function toggleSolution(pid) {
  const el = document.getElementById('sol-'+pid);
  if(el) el.classList.toggle('open');
}

function loadMore() {
  shownCount += 20;
  renderProblems();
}
</script>
